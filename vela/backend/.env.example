# Vela — Backend environment variables
# Copy this file to .env (which is gitignored) and fill in real values.
# NEVER commit real secrets. NEVER expose these in frontend code.

# Server
PORT=4000

# Plaid — dashboard.plaid.com → Team Settings → Keys
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
# sandbox | development | production
PLAID_ENV=sandbox

# Supabase — Project Settings → API
# URL is the same as the frontend's VITE_SUPABASE_URL
SUPABASE_URL=https://your-project-ref.supabase.co
# Service role key — bypasses RLS. KEEP SECRET. Server-only.
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Anthropic — console.anthropic.com → API Keys
# Sage uses Claude Haiku 4.5. Set a $25/mo spending cap at
# console.anthropic.com/settings/limits to bound your worst-case bill.
ANTHROPIC_API_KEY=sk-ant-your-key

# Google Gemini — optional fallback only, not currently used by Sage
# Free tier at aistudio.google.com/apikey
GEMINI_API_KEY=

# CORS — comma-separated list of allowed origins (frontend URLs)
# Local dev default works without setting this.
CORS_ORIGINS=http://localhost:5173
