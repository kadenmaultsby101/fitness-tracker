# Vela — Frontend environment variables
# Copy this file to .env.local (which is gitignored) and fill in real values.
# Vite only exposes vars prefixed with VITE_ to the client bundle.

# Supabase — Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Backend API base URL
# Local dev: http://localhost:4000
# Production: https://your-render-service.onrender.com
VITE_API_URL=http://localhost:4000
